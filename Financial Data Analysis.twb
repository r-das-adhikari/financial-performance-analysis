      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0m9s7k61o3l0ls15m82f40p1fnnt].[sum:Calculation_1254284602310656:qk]&quot;' value='Budget ' />
          <alias key='&quot;[federated.0m9s7k61o3l0ls15m82f40p1fnnt].[usr:Calculation_1917838460477442:qk]&quot;' value='Actual Revenue' />
        </aliases>
      </column>
      <column caption='Budget Utilisation %' datatype='real' name='[Calculation_1129490128453633]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1254284602437633])/SUM([Calculation_1254284602310656])' />
      </column>
      <column caption='Budget Revenue (Fixed)' datatype='integer' name='[Calculation_1254284602310656]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [business_unit], YEAR([transaction_date]), MONTH([transaction_date]) : &#13;&#10;  MIN([budgeted_revenue]) }' />
      </column>
      <column caption='Budget Expense (Fixed)' datatype='integer' name='[Calculation_1254284602437633]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [business_unit], YEAR([transaction_date]), MONTH([transaction_date]) : &#13;&#10;MIN([budgeted_expense]) }' />
      </column>
      <column caption='YoY Label' datatype='string' name='[Calculation_1292217324052480]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF YEAR([transaction_date]) = 2023&#13;&#10;THEN &quot;▲ 29.1% vs 2022&quot;&#13;&#10;ELSE &quot;&quot;&#13;&#10;END' />
      </column>
      <column caption='Region %' datatype='real' name='[Calculation_1335098403131392]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1917838460477442]) / TOTAL([Calculation_1917838460477442]) * 100'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Budget Rev Clean' datatype='real' name='[Calculation_1335098446196737]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED YEAR([transaction_date]) : SUM([budgeted_revenue]) / &#13;&#10;COUNTD(STR(MONTH([transaction_date])) + [business_unit]) * &#13;&#10;COUNTD(STR(MONTH([transaction_date])) + [business_unit]) }' />
      </column>
      <column caption='Monthly Expense' datatype='real' name='[Calculation_1356539571490818]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED YEAR([transaction_date]),MONTH([transaction_date]) : SUM(IF [account_type]=&apos;Expense&apos;&#13;&#10;THEN  [amount_abs] ELSE 0 END) }' />
      </column>
      <column caption='Monthly Budget Expense' datatype='integer' name='[Calculation_1356539596525571]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED YEAR([transaction_date]),MONTH([transaction_date]):SUM([Calculation_1254284602437633]) }' />
      </column>
      <column caption='Over Budget Month Flag' datatype='integer' name='[Calculation_1356539596931076]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1356539571490818] &gt; [Calculation_1356539596525571] THEN 1 ELSE 0 END' />
      </column>
      <column caption='Over Budget Months' datatype='integer' name='[Calculation_1356539597398021]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : SUM([Calculation_1356539596931076]) }' />
      </column>
      <column caption='Cost Spike flat' datatype='boolean' name='[Calculation_1356539635773448]' role='measure' type='nominal'>
        <calculation class='tableau' formula='(ZN([Calculation_1917838460841987]) - LOOKUP(ZN([Calculation_1917838460841987]), -1)) / &#13;&#10;ABS(LOOKUP(ZN([Calculation_1917838460841987]), -1)) * 100 &gt; 15'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Revenue Per customer' datatype='real' name='[Calculation_1656431751618560]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1917838460477442]/COUNTD([customer_id (Customers)])' />
      </column>
      <column caption='Spend Per Vendor' datatype='real' name='[Calculation_1656431751852033]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1917838460841987]/COUNTD([vendor_id (Vendors)])' />
      </column>
      <column caption='Cumulative Revenue %' datatype='real' name='[Calculation_1656431752044546]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RUNNING_SUM(SUM(IF [account_type] = &apos;Revenue&apos; THEN [amount] ELSE 0 END)) /&#13;&#10;TOTAL(SUM(IF [account_type] = &apos;Revenue&apos; THEN [amount] ELSE 0 END)) * 100'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Customer Join Year' datatype='integer' name='[Calculation_1656431752323075]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR([join_date])' />
      </column>
      <column caption='Active Vendor %' datatype='real' name='[Calculation_1656431752523780]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [active]=&apos;Y&apos; THEN [vendor_id (Vendors)] END)/COUNTD([vendor_id (Vendors)])' />
      </column>
      <column caption='Cumulative Spend %' datatype='real' name='[Calculation_1656431752937477]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RUNNING_SUM(SUM(IF [account_type] = &apos;Expense&apos; THEN [amount_abs] ELSE 0 END)) /&#13;&#10;TOTAL(SUM(IF [account_type] = &apos;Expense&apos; THEN [amount_abs] ELSE 0 END)) * 100'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Customer Revenue LOD' datatype='real' name='[Calculation_1656431753150470]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [customer_id] : SUM(IF [account_type] = &apos;Revenue&apos; THEN [amount] ELSE 0 END) }' />
      </column>
      <column caption='Top Customer Revenue' datatype='real' name='[Calculation_1656431753789447]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX([Calculation_1656431753150470]) }' />
      </column>
      <column caption='80% threshold' datatype='real' name='[Calculation_1656431799627789]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1917838460841987]*[Parameters].[Parameter 1]' />
      </column>
      <column caption='Total Revenue' datatype='real' name='[Calculation_1917838460477442]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [account_type]=&apos;Revenue&apos; THEN [amount_abs] ELSE 0 END)' />
      </column>
      <column caption='Total Expense' datatype='real' name='[Calculation_1917838460841987]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [account_type]=&apos;Expense&apos; THEN [amount_abs] ELSE 0 END)' />
      </column>
      <column caption='Net Profit' datatype='real' name='[Calculation_1917838461140996]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1917838460477442]-[Calculation_1917838460841987]' />
      </column>
      <column caption='Gross Margin %' datatype='real' name='[Calculation_1917838467489797]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1917838461140996]/[Calculation_1917838460477442])*100' />
      </column>
      <column caption='Budget Variance Revenue' datatype='real' name='[Calculation_1917838467792902]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1917838460477442] -SUM([Calculation_1254284602310656])' />
      </column>
      <column caption='Budget Variance Expense' datatype='real' name='[Calculation_1917838468005895]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1917838460841987]- SUM([Calculation_1254284602437633])' />
      </column>
      <column caption='Revenue per Employee' datatype='real' name='[Calculation_1917838468272136]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1917838460477442]/COUNTD([federated.1u2f7vr0d8gr7a1g3t2vg0zi2md9].[employee_id])' />
      </column>
      <column caption='Profit Color Flag' datatype='string' name='[Calculation_1917838468730889]' role='measure' type='nominal'>
        <calculation class='tableau' formula='(IF [Calculation_1917838461140996]&gt;=0 THEN &apos;Profit&apos; ELSE &apos;Loss&apos; END)' />
      </column>
      <column caption='Month-Year ' datatype='string' name='[Calculation_1917838469066762]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='STR(YEAR([transaction_date])) + &apos;-&apos; + RIGHT(&apos;0&apos; + STR(MONTH([transaction_date])), 2)' />
      </column>
      <column caption='YoY Growth %' datatype='real' name='[Calculation_2097334178508800]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM(IF YEAR([transaction_date]) = 2023 AND [account_type] = &apos;Revenue&apos; THEN [amount] END) -&#13;&#10; SUM(IF YEAR([transaction_date]) = 2022 AND [account_type] = &apos;Revenue&apos; THEN [amount] END)) /&#13;&#10;SUM(IF YEAR([transaction_date]) = 2022 AND [account_type] = &apos;Revenue&apos; THEN [amount] END) * 100' />
      </column>
